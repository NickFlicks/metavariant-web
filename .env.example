# Base URL for static assets (images, icons) once resources/ is hosted on Cloudflare
# (Cloudflare Pages project or a public R2 bucket URL). Leave unset to serve assets from
# this app's own origin (resources/ is copied into the build as-is).
#
# Example:
# VITE_ASSETS_BASE_URL=https://assets.metavariantapp.com
VITE_ASSETS_BASE_URL=
