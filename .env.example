# Base URL for static assets (images, icons) once resources/ is hosted on Cloudflare
# (Cloudflare Pages project or a public R2 bucket URL). Leave unset to serve assets from
# this app's own origin (resources/ is copied into the build as-is).
#
# Example:
# VITE_ASSETS_BASE_URL=https://assets.metavariantapp.com
VITE_ASSETS_BASE_URL=

# Cloudflare Turnstile SITE key (public, safe to expose client-side) for the
# /contact form's bot check. Get one at dash.cloudflare.com > Turnstile.
# Leave unset to hide the widget and skip Turnstile verification entirely
# (not recommended for production: functions/api/contact.js fails closed and
# rejects every submission if TURNSTILE_SECRET_KEY is set but no token is sent).
VITE_TURNSTILE_SITE_KEY=

# The two vars below are read by functions/api/contact.js (server-side only)
# and must be set in the Cloudflare Pages dashboard under Settings >
# Environment variables, NOT in this file / not exposed to the client:
#   RESEND_API_KEY        - from resend.com
#   TURNSTILE_SECRET_KEY   - paired secret for VITE_TURNSTILE_SITE_KEY above
